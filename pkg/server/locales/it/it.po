msgid "%[1]s (%[2]d point)"
msgid_plural "%[1]s (%[2]d points)"
msgstr[0] "%[1]s (%[2]d punto)"
msgstr[1] "%[1]s (%[2]d punti)"

msgid "%s accepted double."
msgstr "%d accetta il raddoppio."

msgid "%s declined double offer."
msgstr "%s ha rifiutato l'offerta di raddoppio."

msgid "%s disconnected."
msgstr "%s si è disconnesso."

msgid "%s is online."
msgstr "%s è online."

msgid "%[1]s offers a double (%[2]d point)."
msgid_plural "%[1]s offers a double (%[2]d points)."
msgstr[0] "%[1]s offre un raddoppio (%[2]d punto)."
msgstr[1] "%[1]s offre un raddoppio (%[2]d punti)."

msgid "%s resigned."
msgstr "%s si è ritirato."

msgid "Accepted double."
msgstr "Raddoppio accettato."

msgid "Achievement unlocked: %s"
msgstr "Obiettivo sbloccato: %s"

msgid "Blocked opponent from entering for 7 consecutive turns"
msgstr "Impedito all'avversario di entrare per 7 turni consecutivi"

msgid "Boogie Wonderland"
msgstr ""

#, fuzzy
msgid ""
"Bots are not allowed to join player matches. Please create a match instead."
msgstr ""
"I bot non possono aggiungersi alle partite dei giocatori. Creare una partita."

msgid "Choose which doubles you want for your acey-deucey."
msgstr "Scegli il raddoppio per il tuo acey-deucey."

msgid "Command ignored: You are spectating this match."
msgstr "Comando ignorato: sei uno spettatore di questa partita."

msgid ""
"Connect with other players and stay up to date on the latest changes. Visit "
"%s"
msgstr ""
"Entra in contatto con altri giocatori e rimani aggiornato sulle ultime "
"novità. Visita %s"

msgid "Created match: %s"
msgstr "Partita creata: %s"

msgid "Declined double offer."
msgstr "Offerta di raddoppio rifutata."

msgid "Double offered to opponent (%d point)."
msgid_plural "Double offered to opponent (%d points)."
msgstr[0] "Raddoppio offerto all'avversario (%d punto)."
msgstr[1] "Raddoppio offerto all'avversario (%d punti)."

msgid "Double Trouble"
msgstr "Doppio guaio"

msgid ""
"Due to ongoing abuse, only registered users may connect. Please register an "
"account or try again later."
msgstr ""
"A causa di continui abusi, solo gli utenti registrati possono connettersi. "
"Registra un account o riprova più tardi."

msgid "Due to ongoing abuse, registration is disabled. Please try again later."
msgstr ""
"A causa di violazioni, la registrazione è disabilitata. Per favore, riprova "
"più tardi."

msgid ""
"Due to ongoing abuse, some actions are restricted to registered users only. "
"Please log in or register to avoid interruptions."
msgstr ""
"A causa di abusi in corso, alcune azioni sono abilitate ai soli utenti "
"registrati. Per favore, registrati o fai log in per evitare interruzioni."

msgid ""
"Due to ongoing abuse, some actions may become restricted to registered users "
"only. Please log in or register to avoid interruptions."
msgstr ""
"A causa di continui abusi, alcune azioni potrebbero essere limitate ai soli "
"utenti registrati. Effettua il login o registrati per evitare interruzioni."

msgid "Failed to change password."
msgstr "Impossibile cambiare la password."

msgid "Failed to change password: incorrect existing password."
msgstr "Impossibile cambiare la password: password corrente incorretta."

msgid "Failed to change password: you are logged in as a guest."
msgstr "Impossibile cambiare password: sei registrato come ospite."

msgid "Failed to create match: %s"
msgstr "Impossibile creare una partita: %s"

msgid "Failed to log in: %s"
msgstr "Impossibile effettuare l'accesso: %s"

msgid ""
"Failed to register: Invalid username: must contain at least one non-numeric "
"character."
msgstr ""
"Registrazione non riuscita: nome utente non valido: deve contenere almeno un "
"carattere non numerico."

msgid "Flawless Victory"
msgstr "Vittoria impeccabile"

msgid "Good Game"
msgstr "Buona partita"

msgid "Hidden Layer"
msgstr "Livello nascosto"

msgid "Illegal move."
msgstr "Mossa illegale."

msgid "Invalid password."
msgstr "Password non valida."

msgid "Invalid replay ID provided."
msgstr "ID di replay non valido."

msgid "Invalid username: must be %d characters or less."
msgstr "Nome utente non valido: deve contenere al massimo %d caratteri."

msgid "Invalid username: must contain at least one non-numeric character."
msgstr ""
"Nome utente non valido: deve contenere almeno un carattere non numerico."

msgid "Invalid username: must contain only letters, numbers and underscores."
msgstr ""
"Nome utente non valido: deve contenere solo lettere, numeri e trattini bassi."

msgid "It is not your turn to move."
msgstr "Non è il tuo turno di giocare."

msgid "It is not your turn to roll."
msgstr "Non è il tuo turno di tirare."

msgid "It is not your turn."
msgstr "Non è il tuo turno."

msgid "Joined match: %s"
msgstr "Partita congiunta: %s"

msgid "Left completed match."
msgstr "Ha lasciato la partita completata."

msgid "Match not found."
msgstr "Partita non trovata."

msgid "Message not sent: There is no one else in the match."
msgstr "Messaggio non inviato: non ci sono altri giocatori nella partita."

msgid "Message not sent: You are not currently in a match."
msgstr "Messaggio non inviato: al momento non sei in una partita."

msgid "Mind Over Matter"
msgstr "La mente vince sulla materia"

msgid "Network Effect"
msgstr "Effetto rete"

msgid ""
"No account was found with the provided username and password. To log in as a "
"guest, do not enter a password."
msgstr ""
"Non è stato trovato alcun account con il nome utente e la password forniti. "
"Per accedere come ospite, non inserire alcuna password."

msgid "No replay was recorded for that game."
msgstr "Non è stata registrata alcuno replay di quella partita."

msgid "Password changed successfully."
msgstr "Password modificata con successo."

msgid "Please enter an email, username and password."
msgstr "Inserisci un indirizzo e-mail, un nome utente e una password."

msgid "Please finish your match as soon as possible."
msgstr "Si prega di terminare la partita il prima possibile."

msgid "Please leave the match you are in before creating another."
msgstr "Esci dalla partita corrente prima di crearne una nuova."

msgid "Please leave the match you are in before joining another."
msgstr "Esci dalla partita corrente prima di partecipare a un'altra."

msgid "Rejoined match: %s"
msgstr "Partita ripresa: %s"

msgid "Rematch offer sent."
msgstr "Offerta di rivincita inviata."

msgid "Resigned."
msgstr "Dimesso."

msgid "Scored a backgammon against BOT_tabula"
msgstr "Ha segnato un backgammon contro BOT_tabula"

msgid "Scored a backgammon against BOT_wildbg"
msgstr "Ha segnato un backgammon contro BOT_wildbg"

msgid "Scored a backgammon against a human"
msgstr "Ha segnato un backgammon contro un umano"

msgid "Scored a gammon against BOT_tabula"
msgstr "Ha segnato un gammon contro BOT_tabula"

msgid "Scored a gammon against BOT_wildbg"
msgstr "Ha segnato un gammon contro BOT_wildbg"

msgid "Scored a gammon against a human"
msgstr "Ha segnato un gammon contro un umano"

msgid "Scored a normal win against BOT_tabula"
msgstr "Ha ottenuto una vittoria normale contro BOT_tabula"

msgid "Scored a normal win against BOT_wildbg"
msgstr "Ha ottenuto una vittoria normale contro BOT_wildbg"

msgid "Scored a normal win against a human"
msgstr "Ha ottenuto una vittoria normale contro un umano"

msgid "SERVER BROADCAST:"
msgstr "TRASMISSIONE SERVER:"

