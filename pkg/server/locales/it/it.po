msgstr "Errore server"

msgid "That username is already in use."
msgstr "Quel nome utente è già in uso."

msgid "The following legal moves are available: %s"
msgstr "Sono disponibili le seguenti mosse legali: %s"

msgid "The match you are in is still in progress."
msgstr "La partita a cui stai partecipando è ancora in corso."

msgid "The server is shutting down. Reason: %s"
msgstr "Il server si sta spegnendo. Motivo: %s"

msgid "The server is shutting down in %d minute. Reason:"
msgid_plural "The server is shutting down in %d minutes. Reason:"
msgstr[0] "Il server si spegnerà tra %d minuto. Motivo:"
msgstr[1] "Il server si spegnerà tra %d minuti. Motivo:"

